{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build solution",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-clp:NoSummary",
        "${workspaceFolder}/RhinoSpatial.sln"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "build RhinoSpatial plugin",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-clp:NoSummary",
        "${workspaceFolder}/RhinoSpatial/RhinoSpatial.csproj"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "run console sandbox",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/RhinoSpatial.Sandbox.csproj"
      ],
      "presentation": {
        "reveal": "always",
        "clear": true
      }
    }
  ]
}
